{
    "manifest_version": 3,
    "name": "eAccounting Hide Browser Update",
    "version": "1.0",
    "description": "Hide eAccounting Update your Browser popup",
    "content_scripts": [
        {
            "matches": ["https://eaccounting.vismaonline.com/"],
            "js": ["hide-dialog.js"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@eaccounting-hide-browser-update",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}